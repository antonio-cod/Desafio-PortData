generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
   url      = env("DATABASE_URL")
}


model Contact {
  id        String @id @default(uuid())
  name      String @unique
  phone     String @unique

  createdAt DateTime @default(now() ) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("contacts")
}
